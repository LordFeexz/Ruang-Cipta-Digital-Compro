---
import { getContent } from "../../../content";
import LanguageSwitcher from "../common/LanguageSwitcher.svelte";
import MobileMenu from "../common/MobileMenu.svelte";
import { DEFAULT_LANG } from "../../../lib/i18n";
import { Button } from "../ui/button";
import logoImg from "../../../assets/logo.png";

interface Props {
  lang?: string;
}

const { lang = DEFAULT_LANG } = Astro.props;
const content = getContent(lang);
const nav = content.nav;
---

<header class="fixed top-0 left-0 right-0 z-40 bg-background/80 backdrop-blur-md border-b border-white/5 transition-all duration-300">
  <div class="container mx-auto px-4 sm:px-6 h-20 flex items-center justify-between">
    <a href={`/${lang}`} class="flex items-center gap-3 group">
      <img src={logoImg.src} alt="Ruang Cipta Digital" class="h-8 sm:h-10 w-auto group-hover:scale-105 transition-transform" />
      <span class="font-bold text-lg sm:text-xl tracking-tight hidden sm:block">Ruang Cipta Digital</span>
    </a>

    <nav class="hidden md:flex items-center gap-8 font-medium">
      <a href={`/${lang}/career-mate`} class="text-sm hover:text-brand-primary transition-colors">{nav.careerMate}</a>
      <a href={`/${lang}/digitool`} class="text-sm hover:text-brand-primary transition-colors">{nav.digiTool}</a>
    </nav>

    <div class="hidden md:flex items-center gap-4">
      <LanguageSwitcher currentLang={lang} client:load />
      <Button href={`mailto:${import.meta.env.PUBLIC_CONTACT_EMAIL}`} class="rounded-full bg-brand-gradient hover:opacity-90 text-white shadow-lg shadow-brand-primary/20">
        {nav.contact}
      </Button>
    </div>

    <!-- Mobile Navigation -->
    <div class="md:hidden flex items-center gap-2">
      <MobileMenu lang={lang} navItems={nav} client:load />
    </div>
  </div>
</header>
