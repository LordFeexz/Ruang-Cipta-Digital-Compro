---
import { cn } from "../../../lib/utils";

interface Props {
  class?: string;
  id?: string;
}

const { class: className = "", id } = Astro.props;
---

<section id={id} class={cn("py-20 sm:py-32 relative overflow-hidden", className)} data-aos="fade-up">
  <div class="container mx-auto px-4 sm:px-6 relative z-10">
    <slot />
  </div>
</section>
