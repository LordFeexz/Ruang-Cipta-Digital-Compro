---
import SectionWrapper from "./SectionWrapper.astro";
import GlowCard from "./GlowCard.astro";
import { Button } from "../ui/button";
import type { ProductCardContent } from "../../../content/types";
import ArrowRight from "@lucide/svelte/icons/arrow-right";

interface Props {
  products: ProductCardContent[];
}

const { products } = Astro.props;
---

<SectionWrapper>
  <div class="max-w-3xl mx-auto text-center mb-16">
    <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight mb-6">
      What We Build
    </h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
    {
      products.map((product) => (
        <GlowCard class="flex flex-col h-full">
          <div class="grow">
            <div class="inline-block px-3 py-1 rounded-full bg-brand-primary/10 text-brand-primary text-sm font-semibold mb-6">
              Ecosystem Product
            </div>
            <h3 class="text-3xl font-bold tracking-tight mb-4">
              {product.name}
            </h3>
            <p class="text-xl text-muted-foreground font-medium mb-4">
              {product.description}
            </p>
            <p class="text-foreground/80 mb-8">{product.valueProp}</p>
          </div>

          <div class="mt-auto pt-8 border-t border-white/5">
            <Button
              href={product.link}
              target="_blank"
              rel="noopener noreferrer"
              variant="ghost"
              class="w-full justify-between group hover:bg-white/5"
            >
              {product.cta}
              <span class="group-hover:translate-x-1 transition-transform inline-flex items-center justify-center">
                <ArrowRight size={16} />
              </span>
            </Button>
          </div>
        </GlowCard>
      ))
    }
  </div>
</SectionWrapper>
