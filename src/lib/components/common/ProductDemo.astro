---
import SectionWrapper from "./SectionWrapper.astro";
import type { FeatureDemo } from "../../../content/types";
import CheckCircle2 from "@lucide/svelte/icons/check-circle-2";
import { cn } from "../../../lib/utils";

interface Props {
  demo: FeatureDemo;
}

const { demo } = Astro.props;
---

<SectionWrapper class="bg-card/50">
  <div class="max-w-3xl mx-auto text-center mb-16">
    <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight mb-4">
      {demo.title}
    </h2>
  </div>

  <div
    class="grid grid-cols-1 lg:grid-cols-12 gap-12 max-w-7xl mx-auto items-center"
  >
    <!-- UI Mockup -->
    <div
      class="lg:col-span-7 order-2 lg:order-1" data-aos="zoom-in" data-aos-duration="1000"
    >
      <div
        class="relative rounded-xl border border-white/10 bg-background shadow-2xl overflow-hidden aspect-16/10"
      >
        <!-- Browser Bar -->
        <div
          class="h-10 bg-card border-b border-white/5 flex items-center px-4 gap-2"
        >
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
          </div>
          <div class="mx-auto h-5 w-1/2 max-w-sm bg-white/5 rounded-md"></div>
        </div>

        <!-- Mockup Content Area -->
        <div class="p-6 h-full flex flex-col gap-6">
          <div class="flex items-center justify-between">
            <div class="w-32 h-6 bg-white/10 rounded-md"></div>
            <div class="flex gap-4">
              <div class="w-16 h-6 bg-white/5 rounded-md"></div>
              <div class="w-16 h-6 bg-white/5 rounded-md"></div>
              <div class="w-8 h-8 bg-brand-primary/20 rounded-full"></div>
            </div>
          </div>

          <div class="flex gap-6 h-full">
            <!-- Sidebar -->
            <div class="w-48 hidden md:flex flex-col gap-3">
              <div class="w-full h-8 bg-brand-primary/10 rounded-md"></div>
              <div class="w-full h-8 bg-white/5 rounded-md"></div>
              <div class="w-full h-8 bg-white/5 rounded-md"></div>
              <div class="w-full h-8 bg-white/5 rounded-md"></div>
            </div>

            <!-- Main Content Grid -->
            <div class="grow grid grid-cols-2 gap-4">
              <div
                class="col-span-2 h-32 bg-linear-to-br from-brand-primary/20 to-brand-secondary/20 rounded-xl border border-white/5"
              >
              </div>
              <div class="h-40 bg-card rounded-xl border border-white/5"></div>
              <div class="h-40 bg-card rounded-xl border border-white/5"></div>
              <div
                class="col-span-2 h-24 bg-card rounded-xl border border-white/5"
              >
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Feature List -->
    <div class="lg:col-span-5 order-1 lg:order-2">
      <div class="space-y-6">
        {
          demo.features.map((feature, index) => (
            <div
              class={cn(
                "flex items-start gap-4 p-4 rounded-xl hover:bg-white/5 transition-colors cursor-default",
              )}
              data-aos="fade-up"
              data-aos-delay={index * 150}
            >
              <div class="mt-1">
                <CheckCircle2 class="h-6 w-6 text-brand-primary" />
              </div>
              <div>
                <h3 class="text-xl font-bold mb-1">{feature}</h3>
                <div class="w-full h-1 bg-white/5 mt-3 rounded-full overflow-hidden">
                  <div class="h-full bg-brand-gradient w-1/3 opacity-50" />
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</SectionWrapper>
