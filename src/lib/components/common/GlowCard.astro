---
import { cn } from "../../../lib/utils";

interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div class={cn("relative group rounded-2xl", className)} data-aos="fade-up" data-aos-duration="600">
  <div
    class="absolute -inset-px bg-linear-to-r from-brand-primary to-brand-secondary rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-[2px]"
  >
  </div>
  <div
    class="relative h-full bg-card border border-white/5 rounded-2xl p-6 sm:p-8 overflow-hidden transition-colors duration-500 hover:bg-card/80"
  >
    <slot />
  </div>
</div>
